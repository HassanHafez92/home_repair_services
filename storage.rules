rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ═══════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    /// Validate that uploaded file is an image and under 10MB.
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }

    /// Validate that uploaded file is audio and under 5MB.
    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    // ═══════════════════════════════════════════════════════════════════
    // VOICE NOTES
    // ═══════════════════════════════════════════════════════════════════
    match /voice_notes/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidAudio();
    }

    // ═══════════════════════════════════════════════════════════════════
    // RECEIPT IMAGES (Live camera captures only)
    // ═══════════════════════════════════════════════════════════════════
    match /receipt_images/{techId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(techId) && isValidImage();
    }

    // ═══════════════════════════════════════════════════════════════════
    // KYC DOCUMENTS
    // ═══════════════════════════════════════════════════════════════════
    match /kyc_documents/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidImage();
    }

    // ═══════════════════════════════════════════════════════════════════
    // PROFILE PHOTOS
    // ═══════════════════════════════════════════════════════════════════
    match /profile_photos/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidImage();
    }
  }
}
