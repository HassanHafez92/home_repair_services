rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════

    /// Check if the requester is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Check if the requester is the document owner.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /// Check if the requester has admin custom claim.
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    /// Check if the requester has technician role.
    function isTechnician() {
      return isAuthenticated() && request.auth.token.role == 'technician';
    }

    // ═══════════════════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Users can read their own profile; admins can read all.
      allow read: if isOwner(userId) || isAdmin();
      // Users can create their own profile on first login.
      allow create: if isOwner(userId);
      // Users can update their own profile (except role and isBlocked).
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isBlocked']);
      // Only admins can delete users or change roles/block status.
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // User notification subcollection
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow write: if isAdmin();
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // TECHNICIAN PROFILES COLLECTION
    // ═══════════════════════════════════════════════════════════════════
    match /technician_profiles/{techId} {
      // Technicians can read their own profile; admins can read all.
      allow read: if isOwner(techId) || isAdmin();
      // Technicians can create/update their own profile.
      allow create: if isOwner(techId);
      // Technicians can update non-sensitive fields.
      allow update: if isOwner(techId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'verificationStatus', 'averageRating', 'totalJobs', 'totalReviews'
        ]);
      // Admins have full access (for KYC approval/rejection).
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // JOBS COLLECTION
    // ═══════════════════════════════════════════════════════════════════
    match /jobs/{jobId} {
      // Customers can read their own jobs; assigned technicians can read theirs.
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.technicianId == request.auth.uid ||
        isAdmin()
      );
      // Only authenticated users can create jobs (via Cloud Functions preferred).
      allow create: if isAuthenticated();
      // Technicians can update assigned jobs (status, invoice data).
      allow update: if isAuthenticated() && (
        resource.data.technicianId == request.auth.uid ||
        resource.data.customerId == request.auth.uid ||
        isAdmin()
      );
      // Only admins can delete jobs.
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // TECH TELEMETRY (LIVE LOCATION)
    // ═══════════════════════════════════════════════════════════════════
    match /tech_telemetry/{techId} {
      // Technicians can write their own location.
      allow write: if isOwner(techId);
      // Anyone authenticated can read (for live tracking).
      allow read: if isAuthenticated();
    }

    // ═══════════════════════════════════════════════════════════════════
    // WALLETS COLLECTION
    // ═══════════════════════════════════════════════════════════════════
    match /wallets/{userId} {
      // Users can only read their own wallet.
      allow read: if isOwner(userId) || isAdmin();
      // Only Cloud Functions / admin can write wallet data.
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // TRANSACTIONS (LEDGER)
    // ═══════════════════════════════════════════════════════════════════
    match /transactions/{txId} {
      // Users can read their own transactions.
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      // Only Cloud Functions / admin can create transactions.
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // DISPUTES COLLECTION
    // ═══════════════════════════════════════════════════════════════════
    match /disputes/{disputeId} {
      // Involved parties and admins can read.
      allow read: if isAuthenticated() && (
        resource.data.reportedBy == request.auth.uid ||
        resource.data.reportedAgainst == request.auth.uid ||
        isAdmin()
      );
      // Authenticated users can create disputes.
      allow create: if isAuthenticated();
      // Only admins can update/resolve disputes.
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // PRICING (SERVER-CONTROLLED, READ-ONLY FOR CLIENTS)
    // ═══════════════════════════════════════════════════════════════════
    match /pricing/{category} {
      // Anyone authenticated can read prices.
      allow read: if isAuthenticated();
      // Only admins can modify pricing.
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // NOTIFICATIONS COLLECTION
    // ═══════════════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // RISK FUND (ADMIN-ONLY)
    // ═══════════════════════════════════════════════════════════════════
    match /risk_fund/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // GEOFENCE ZONES (ADMIN-CONFIGURABLE)
    // ═══════════════════════════════════════════════════════════════════
    match /geofence_zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // APP CONFIG
    // ═══════════════════════════════════════════════════════════════════
    match /app_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
