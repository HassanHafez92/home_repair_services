rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isTechnician() {
      return isAuthenticated() && request.auth.token.role == 'technician';
    }

    function isCustomer() {
      return isAuthenticated() && request.auth.token.role == 'customer';
    }

    // ─── Users ────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Technicians ──────────────────────────────────

    match /technicians/{techId} {
      // Customers can read basic tech info (name, rating, photo)
      allow read: if isAuthenticated();
      allow create: if isOwner(techId);
      allow update: if isOwner(techId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Jobs ─────────────────────────────────────────

    match /jobs/{jobId} {
      // Customer and assigned technician can read
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.technicianId == request.auth.uid ||
        isAdmin()
      );

      // Only server-side (Cloud Functions) should create jobs
      // But customers can create via a limited set of fields
      allow create: if isCustomer() && request.resource.data.customerId == request.auth.uid;

      // Status updates only via Cloud Functions
      // Customers can only rate and respond to invoices
      allow update: if isAuthenticated() && (
        isAdmin() ||
        // Customer can rate
        (resource.data.customerId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'ratingComment', 'ratedAt'])) ||
        // Technician can update status
        (resource.data.technicianId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
      );

      allow delete: if isAdmin();
    }

    // ─── Wallets ──────────────────────────────────────

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Only Cloud Functions can write to wallets (atomic operations)
      allow write: if false;

      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    // ─── Notifications ────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false; // Only Cloud Functions
    }

    // ─── Pricing (Read-only for clients) ──────────────

    match /pricing/{category} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Disputes ─────────────────────────────────────

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.technicianId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── Platform Config (Admin only) ─────────────────

    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
